<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Students Dashboard - Gradly</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">

    <style>
        /* Agar ye classes pehle se style.css me nahi hain toh cards ko theme se match karne ke liye custom CSS */
        .student-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .student-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(139, 92, 246, 0.15); /* Purple neon shadow on hover */
            border-color: rgba(139, 92, 246, 0.5);
        }

        .profile-img {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #8b5cf6; /* Primary purple color */
            padding: 3px;
            margin: auto;
            background: #0f172a;
        }
    </style>
</head>

<body>

    <div class="glow"></div>

    <nav class="navbar navbar-expand-lg navbar-dark py-3">
        <div class="container">
            <a class="navbar-brand fs-4" href="/students">
                🎓 Gradly
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="navMenu">
                <ul class="navbar-nav gap-3 align-items-center">
                    <% if (isLoggedIn) { %>
                        <li class="nav-item">
                            <a class="nav-link text-light" href="/students/profile">My Profile</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-danger" href="/students/logout">Logout</a>
                        </li>
                    <% } else { %>
                        <li class="nav-item">
                            <a class="nav-link text-light" href="/students/login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary" href="/students/register">Sign Up</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container py-5 mt-3">
        <div class="text-center mb-5 heading-wrapper">
            <span class="aesthetic-subtitle text-primary d-block mb-2">Network</span>
            <!-- <h2 class="text-white fw-bold">🎬 Students Dashboard</h2> -->
        </div>

        <div class="row g-4">

            <% if (students && students.length > 0) { %>
                <% students.forEach((student, index) => { %>
                    <div class="col-md-6 col-lg-4 fade-in-up" style="animation-delay: <%= index * 0.1 %>s;">
                        <div class="card student-card p-4 text-center h-100">
                            
                            <img src="<%= student.image %>" alt="Profile Image" class="profile-img mb-3">

                            <h5 class="text-white fw-semibold mb-1">
                                <%= student.firstName %> <%= student.lastName %>
                            </h5>

                            <p class="text-white small mb-4">
                                <%= student.email %>
                            </p>

                            <div class="mt-auto">
                                <a href="/students/view/<%= student._id %>" class="btn btn-primary w-100 rounded-pill py-2">
                                    View Profile
                                </a>
                            </div>

                        </div>
                    </div>
                <% }) %>

            <% } else { %>
                <div class="col-12 text-center py-5 fade-in-up">
                    <p class="text-muted fs-5">No students found yet. Be the first to join!</p>
                </div>
            <% } %>

        </div>
    </div>

    <footer class="text-center py-4 mt-5 text-muted">
        © 2026 Gradly — Built for Modern Education
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>