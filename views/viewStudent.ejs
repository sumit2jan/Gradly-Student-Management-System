<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Student Profile - Gradly</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">

    <style>
        /* Modern Dark Theme Variables */
        body {
            background-color: #0b0f19;
            color: #f8fafc;
        }

        /* Subtle Background Grid for depth */
        .bg-grid {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image:
                linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px),
                linear-gradient(to bottom, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
            background-size: 50px 50px;
            z-index: -1;
            pointer-events: none;
        }

        /* Discord/Twitter Style Profile Card */
        .profile-card {
            background: rgba(17, 24, 39, 0.7);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        /* Gradient Banner Top */
        .profile-banner {
            height: 180px;
            background: linear-gradient(135deg, #4f46e5 0%, #9333ea 50%, #ec4899 100%);
            position: relative;
        }

        /* Avatar overlapping the banner */
        .avatar-wrapper {
            margin-top: -70px;
            position: relative;
            z-index: 10;
        }

        .profile-img-main {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            object-fit: cover;
            border: 6px solid #111827;
            /* Matches card background to create cutout effect */
            background: #1e293b;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
        }

        /* Fixing the Text Contrast */
        .text-light-gray {
            color: #94a3b8 !important;
            /* Lighter gray for better visibility */
        }

        /* Gradient Text for Headings */
        .text-gradient {
            background: linear-gradient(to right, #a855f7, #ec4899);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-weight: bold;
        }

        /* Glassmorphism Buttons */
        .btn-glass {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            backdrop-filter: blur(10px);
            transition: all 0.3s;
        }

        .btn-glass:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            transform: translateY(-2px);
            border-color: #a855f7;
        }

        /* Empty State Styling */
        .empty-state {
            background: rgba(17, 24, 39, 0.5);
            border: 2px dashed rgba(168, 85, 247, 0.3);
            border-radius: 20px;
            padding: 3rem;
            transition: all 0.3s ease;
        }

        .empty-state:hover {
            border-color: rgba(168, 85, 247, 0.8);
            background: rgba(168, 85, 247, 0.05);
        }

        .student-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .student-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(139, 92, 246, 0.15);
            /* Purple neon shadow on hover */
            border-color: rgba(139, 92, 246, 0.5);
        }
    </style>
</head>

<body>

    <div class="bg-grid"></div>
    <nav class="navbar navbar-expand-lg navbar-dark py-3">
        <div class="container">
            <a class="navbar-brand fs-4" href="/students">
                🎓 Gradly
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="navMenu">
                <ul class="navbar-nav gap-3 align-items-center">
                    <% if (isLoggedIn) { %>
                        <li class="nav-item">
                            <a class="nav-link text-light" href="/students/profile">My Profile</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-danger" href="/students/logout">Logout</a>
                        </li>
                        <% } else { %>
                            <li class="nav-item">
                                <a class="nav-link text-light" href="/students/login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary" href="/students/register">Sign Up</a>
                            </li>
                            <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container py-5 max-w-4xl" style="max-width: 900px;">

        <div class="mb-4">
            <a href="/students/video-dashboard" class="btn btn-glass rounded-pill px-4 py-2 text-decoration-none">
                <span class="me-2">←</span> Back to Dashboard
            </a>
        </div>

        <div class="profile-card mb-5 text-center">

            <div class="profile-banner"></div>

            <div class="p-4 pb-5">
                <div class="avatar-wrapper mb-3">
                    <img src="<%= student.image || '/uploads/default.png' %>" alt="Profile Picture"
                        class="profile-img-main">
                </div>

                <span
                    class="badge bg-primary bg-opacity-25 text-primary border border-primary rounded-pill px-3 py-2 mb-2">
                    Student
                </span>

                <h2 class="fw-bold mb-1 fs-1">
                    <%= student.firstName %>
                        <%= student.lastName %>
                </h2>

                <p class="text-light-gray fs-5 mb-0">
                    <i class="me-2 opacity-75">✉</i>
                    <%= student.email %>
                </p>
            </div>
        </div>

        <hr style="border-color: rgba(255,255,255,0.1); margin: 3rem 0;">

        <div class="text-center mb-5">
            <p class="text-uppercase tracking-widest text-primary fw-bold mb-2"
                style="letter-spacing: 2px; font-size: 0.85rem;">Portfolio</p>
            <h3 class="text-white fw-bold fs-2">Student Videos</h3>
        </div>

        <div class="row g-4">
            <% if (videos && videos.length> 0) { %>
                <% videos.forEach((video)=> { %>
                    <div class="col-md-6 col-lg-4">
                        <div class="card bg-transparent border-0 h-100"
                            style="transition: transform 0.3s; cursor: pointer;"
                            onmouseover="this.style.transform='translateY(-5px)'"
                            onmouseout="this.style.transform='translateY(0)'">
                            <video controls preload="metadata" class="w-100 rounded-4 shadow"
                                style="background: #000; border: 1px solid rgba(255,255,255,0.1);">
                                <source src="<%= video.videoUrl %>" type="video/mp4">
                            </video>
                        </div>
                    </div>
                    <% }) %>
                        <% } else { %>

                            <div class="col-12 text-center">
                                <div class="empty-state mx-auto" style="max-width: 600px;">
                                    <div
                                        style="font-size: 3.5rem; filter: drop-shadow(0 0 15px rgba(168,85,247,0.4)); margin-bottom: 1rem;">
                                        🎬
                                    </div>
                                    <h4 class="text-white fw-semibold mb-2">No Content Yet</h4>
                                    <p class="text-light-gray fs-5 mb-0">This student hasn't uploaded any videos to
                                        their portfolio.</p>
                                </div>
                            </div>

                            <% } %>
        </div>

    </div>

    <footer class="text-center py-4 mt-5 text-light-gray border-top"
        style="border-color: rgba(255,255,255,0.05) !important;">
        © 2026 Gradly — Built for Modern Education
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>